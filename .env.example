# Copy to `.env` and adjust as needed. Never commit `.env`.

# ---- database -----------------------------------------------------------
# Used by both docker-compose (initdb) and the api.
POSTGRES_USER=sb
POSTGRES_PASSWORD=sb
POSTGRES_DB=second_brain
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://sb:sb@localhost:5432/second_brain
DATABASE_URL_SYNC=postgresql+psycopg://sb:sb@localhost:5432/second_brain  # alembic uses sync

# ---- llm provider -------------------------------------------------------
# Provider selection. `mock` is the default so the app boots and tests pass
# even without Ollama or any API key. Switch to `ollama` once you have it
# running and `gemma3:27b-instruct` pulled.
LLM_PROVIDER=mock                # mock | ollama | anthropic | openai
LLM_MODEL=gemma3:27b-instruct    # used when LLM_PROVIDER=ollama
LLM_FALLBACK_MODEL=qwen2.5:32b-instruct  # auto-loaded if tool-call schema fails

OLLAMA_BASE_URL=http://localhost:11434

# Optional — only consulted when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional — only consulted when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- embeddings ---------------------------------------------------------
EMBED_PROVIDER=mock              # mock | ollama
EMBED_MODEL=mxbai-embed-large    # 1024-d when ollama; mock matches the dimension
EMBED_DIM=1024

# ---- reranker -----------------------------------------------------------
RERANKER_PROVIDER=none           # none | flashrank
RERANKER_MODEL=ms-marco-MiniLM-L-12-v2

# ---- chat behaviour -----------------------------------------------------
CHAT_MODE=auto                   # auto | agent | simple
CHAT_MAX_TOOL_CALLS=8
CHAT_CONTEXT_WINDOW_TOKENS=32768

# ---- ingest -------------------------------------------------------------
WORKER_CONCURRENCY=1             # bump to 2 if you want parallel ingest
INGEST_REVIEW_REQUIRED=true      # false to auto-merge LLM-extracted pages (not recommended)

# ---- storage ------------------------------------------------------------
DATA_DIR=./data
WIKI_SEED_PATH=./wiki            # imported on `make seed`

# ---- app ----------------------------------------------------------------
API_PORT=8000
WEB_PORT=3000
DEFAULT_VAULT_SLUG=ai-engineering
LOG_LEVEL=INFO
